# ==========================================
# LeadPilot — Environment template. Copy to .env and fill in.
# ==========================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/voicesummary
# For Supabase-hosted Postgres, use the DIRECT connection (port 5432), NOT the pgbouncer
# transaction pooler (port 6543) — see app/database.py comment for why.
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Sarvam AI — sole provider (STT + diarization + translation + analysis).
# Get keys at https://dashboard.sarvam.ai . Comma-separated = auto-rotated on credit/rate limits.
SARVAM_API_KEYS=your_sarvam_key_1,your_sarvam_key_2
SARVAM_CHAT_MODEL=sarvam-105b          # analysis (sarvam-105b best | sarvam-30b cheap worker)
SARVAM_STT_MODEL=saaras:v3             # batch STT + diarization
SARVAM_STT_MODE=transcribe             # transcribe (original lang) | translate (-> English)
SARVAM_TRANSLATE_MODEL=mayura:v1

# Storage: 'local' for dev (audio on disk) | 'supabase' | 's3' (fill AWS_* below)
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./local_storage
AUDIO_SOURCE_PATH=./Audio
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=

# Supabase (DB host above + optional Storage backend for call audio, storage_mode=supabase).
# SERVICE ROLE key is server-side only — never expose it to Flutter or any client (no
# Supabase Auth/RLS in this app).
# SUPABASE_URL=https://[project-ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_STORAGE_BUCKET=audio-calls

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Frontend / CORS
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
