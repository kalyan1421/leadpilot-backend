# LeadPilot — environment template. Copy to .env and fill in. NEVER commit the real .env.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/voicesummary
# For Supabase-hosted Postgres, use the DIRECT connection (port 5432), NOT the pgbouncer
# transaction pooler (port 6543) — see app/database.py comment for why.
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# --- Sarvam AI (STT + diarization + translation; also default reasoning) ---
# Comma-separated keys; rotated automatically on credit exhaustion / rate limits.
SARVAM_API_KEYS=your_sarvam_key_1,your_sarvam_key_2,your_sarvam_key_3
SARVAM_CHAT_MODEL=sarvam-105b
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TRANSLATE_MODEL=mayura:v1

# --- Reasoning provider (which LLM does post-call ANALYSIS / scoring / sentiment) ---
# STT + diarization ALWAYS stay on Sarvam; this only swaps the reasoning brain.
#   sarvam  -> Indic-tuned, no extra key
#   gemini  -> Gemini 3.1 Pro (stronger general reasoner; needs a billed Gemini key)
REASONING_PROVIDER=sarvam
GEMINI_API_KEYS=your_gemini_key            # comma-separated; rotated on 429/503
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_THINKING_LEVEL=low                  # low | medium | high

# --- Storage ---
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./local_storage
AUDIO_SOURCE_PATH=./Audio

# --- Supabase (DB host above + optional Storage backend for call audio) ---
# Set STORAGE_MODE=supabase to use these. SERVICE ROLE key is server-side only —
# never expose it to Flutter or any client (there is no Supabase Auth/RLS in this app).
# SUPABASE_URL=https://[project-ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_STORAGE_BUCKET=audio-calls

# --- Auth (FastAPI is the sole identity provider — web portals + mobile) ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
